# Android signing passwords (used by Gradle and gen_android_keystore)
KEYSTORE_PASSWORD=
KEY_PASSWORD=

# Base64-encoded keystore (CI only)
# Keystore contains randomness — CI must use the same keystore as local.
# Upload via: just upload-secrets
# KEYSTORE_BASE64=

# GitHub personal access token (fine-grained, public repos read-only).
# Raises API rate limit from 60 to 5000 req/h for update checks.
# Pass to Flutter via: just android release --dart-define=GITHUB_TOKEN=$GITHUB_TOKEN
GITHUB_TOKEN=
